# VITE_GEMINI_API_KEY: Required for Gemini AI API calls (client-side Vite).
# IMPORTANT: Any client-side key can be exposed in the browser. Prefer moving
# AI calls to a backend if you need true secrecy.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase: used for lead capture / saving results
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Google AdSense
VITE_ADSENSE_CLIENT_ID="ca-pub-XXXXXXXXXXXXXXXX"
VITE_ADSENSE_SLOT_INLINE="1234567890"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional: canonical public site URL for SEO
VITE_SITE_URL="https://your-domain.com"
