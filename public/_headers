# Security headers for all routes
/*
  # Prevent clickjacking
  X-Frame-Options: SAMEORIGIN
  
  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff
  
  # Enable XSS protection in older IE
  X-XSS-Protection: 1; mode=block
  
  # Referrer policy
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Permissions policy
  Permissions-Policy: accelerometer=(), camera=(), microphone=(), geolocation=(), payment=(), usb=()
  
  # Content Security Policy - optimized for OneSignal, Supabase, Gemini AI, Google Analytics, AdSense, Stripe
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.onesignal.com https://www.googletagmanager.com https://pagead2.googlesyndication.com https://www.google-analytics.com https://www.google.com https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob: https://*.onesignal.com; connect-src 'self' https://api.onesignal.com https://*.onesignal.com https://onesignal.com https://www.google-analytics.com https://www.googletagmanager.com https://pagead2.googlesyndication.com https://rtsxggxfgnjxwumunlhp.supabase.co https://generativelanguage.googleapis.com https: wss:; frame-src 'self' https://www.google.com https://www.youtube.com https://stripe.com https://pagead2.googlesyndication.com https://googleads.g.doubleclick.net; object-src 'none'; media-src 'self' https:; worker-src 'self' blob:;
  
  # HSTS (HTTP Strict Transport Security) - enforce HTTPS for 1 year
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  
  # Feature policy / Permissions policy
  Feature-Policy: accelerometer 'none'; camera 'none'; microphone 'none'; payment 'self'; usb 'none'

# API routes - no cache
/api/*
  Cache-Control: no-cache, no-store, must-revalidate

# Service worker - always revalidate
/sw.js
  Cache-Control: max-age=0, must-revalidate, public

# Static assets - long cache
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts - long cache
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Images - medium cache
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.svg
/*.webp
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# HTML files - no cache (always check freshness)
/*.html
  Cache-Control: no-cache, public, must-revalidate

# Manifest and robots - cache for 1 day
/manifest.json
/robots.txt
/sitemap.xml
  Cache-Control: public, max-age=86400

# PWA icons
/icon-*.png
/apple-touch-icon.png
  Cache-Control: public, max-age=31536000, immutable

# JSON-LD and structured data
/*.json
  Cache-Control: public, max-age=3600

# Medical content - cache for 1 day
/injuries/*
/insights/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# Enable gzip compression for text files
/*.html
/*.css
/*.js
/*.json
/*.xml
  Content-Encoding: gzip

# Cross-Origin policies
/*
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization
